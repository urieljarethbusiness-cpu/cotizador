# Cotizador E3 — variables de entorno
# Copia este archivo a .env (local) o configúralas en Coolify (producción).

# ── Base de datos (compartida por Next.js y el API Python) ──
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cotizador_e3

# Opcional: solo la usa el CLI de Prisma (migraciones). Si no la defines,
# se construye automáticamente desde las DB_* (ver prisma.config.ts).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cotizador_e3"

# ── Auth ──
# OBLIGATORIA. Genera una con: openssl rand -base64 32
JWT_SECRET=

# ── API Python (api/) — clave para agentes de IA / n8n ──
API_KEY=

# ── Seed (catálogo + usuarios). En producción: RUN_SEED=true solo el primer despliegue ──
RUN_SEED=false
SEED_ADMIN_EMAIL=admin@e3.local
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Administrador
# Asesor opcional: solo se crea si defines el email
SEED_ASESOR_EMAIL=
SEED_ASESOR_PASSWORD=
SEED_ASESOR_NAME=
